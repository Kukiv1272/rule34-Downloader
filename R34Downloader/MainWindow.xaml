<Window x:Class="R34Downloader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:R34Downloader.Resources"
        Title="rule34 Downloader"
        Width="920" Height="640"
        MinWidth="700" MinHeight="480"
        Background="{StaticResource BrushBg}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Consolas">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>  <!-- Заголовок       -->
      <RowDefinition Height="1"/>     <!-- Акцент-линия    -->
      <RowDefinition Height="*"/>     <!-- Тело            -->
      <RowDefinition Height="1"/>     <!-- Разделитель     -->
      <RowDefinition Height="Auto"/>  <!-- Нижняя панель   -->
    </Grid.RowDefinitions>

    <!-- ── Заголовок ──────────────────────────────────────────────────────── -->
    <Border Grid.Row="0" Background="{StaticResource BrushPanel}" Height="52">
      <Grid Margin="20,0">
        <!-- Левая часть: название -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="rule34 " FontSize="18" FontWeight="Bold"
                     Foreground="{StaticResource BrushDim}"/>
          <TextBlock Text="Downloader" FontSize="18" FontWeight="Bold"
                     Foreground="{StaticResource BrushAccent}"/>
        </StackPanel>
        <!-- Правая часть: статус -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                    VerticalAlignment="Center">
          <TextBlock x:Name="StatusLabel" Text="{x:Static res:Strings.StatusIdle}" FontSize="10"
                     Foreground="{StaticResource BrushDim}" Margin="0,0,6,0"
                     VerticalAlignment="Center"/>
          <TextBlock x:Name="StatusDot" Text="●" FontSize="14"
                     Foreground="{StaticResource BrushDim}"
                     VerticalAlignment="Center"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Акцент-линия под заголовком -->
    <Border Grid.Row="1" Background="{StaticResource BrushAccent}"/>

    <!-- ── Тело ───────────────────────────────────────────────────────────── -->
    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="265"/>  <!-- Левая панель конфига -->
        <ColumnDefinition Width="1"/>    <!-- Разделитель          -->
        <ColumnDefinition Width="*"/>    <!-- Правая панель лога   -->
      </Grid.ColumnDefinitions>

      <!-- ── Левая панель конфигурации ──────────────────────────────────── -->
      <ScrollViewer Grid.Column="0"
                    Background="{StaticResource BrushPanel}"
                    VerticalScrollBarVisibility="Auto"
                    Style="{StaticResource DarkScrollViewer}">
        <StackPanel Margin="0,0,0,12">

          <!-- АВТОРИЗАЦИЯ -->
          <TextBlock Text="{x:Static res:Strings.SectionAuth}" FontSize="10"
                     Foreground="{StaticResource BrushDim}"
                     Margin="18,14,18,2"/>

          <TextBlock Text="{x:Static res:Strings.LabelApiKey}" FontSize="11"
                     Foreground="{StaticResource BrushText}"
                     Margin="18,6,18,1"/>
          <PasswordBox x:Name="ApiKeyBox"
                       Style="{StaticResource DarkPasswordBox}"
                       Margin="18,0,18,4"
                       ToolTip="{x:Static res:Strings.ToolTipApiKey}"/>

          <TextBlock Text="{x:Static res:Strings.LabelUserId}" FontSize="11"
                     Foreground="{StaticResource BrushText}"
                     Margin="18,6,18,1"/>
          <TextBox x:Name="UserIdBox"
                   Style="{StaticResource DarkTextBox}"
                   Tag="{x:Static res:Strings.PlaceholderUserId}"
                   Margin="18,0,18,4"/>

          <!-- Разделитель -->
          <Border Height="1" Background="{StaticResource BrushBorder}" Margin="18,6"/>

          <!-- ЗАГРУЗКА -->
          <TextBlock Text="{x:Static res:Strings.SectionDownload}" FontSize="10"
                     Foreground="{StaticResource BrushDim}"
                     Margin="18,8,18,2"/>

          <TextBlock Text="{x:Static res:Strings.LabelTagsFolder}" FontSize="11"
                     Foreground="{StaticResource BrushText}"
                     Margin="18,6,18,1"/>
          <Grid Margin="18,0,18,6">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="38"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="DirBox"
                     Grid.Column="0"
                     Style="{StaticResource DarkTextBox}"
                     Tag="{x:Static res:Strings.PlaceholderDir}"
                     Margin="0,0,4,0"/>
            <Button Grid.Column="1"
                    Content="..."
                    Height="32" Width="34"
                    Background="{StaticResource BrushBorder}"
                    Foreground="{StaticResource BrushText}"
                    FontFamily="Consolas" FontSize="13"
                    BorderThickness="0" Cursor="Hand"
                    Click="BrowseDir_Click"
                    Style="{StaticResource BaseButton}"/>
          </Grid>

          <TextBlock Text="{x:Static res:Strings.LabelThreads}" FontSize="11"
                     Foreground="{StaticResource BrushText}"
                     Margin="18,6,18,1"/>
          <TextBlock x:Name="ThreadsLabel" Text="4"
                     FontSize="13" FontWeight="Bold"
                     Foreground="{StaticResource BrushText}"
                     Margin="18,2,18,0"/>
          <Slider x:Name="ThreadsSlider"
                  Style="{StaticResource DarkSlider}"
                  Minimum="1" Maximum="16" Value="4"
                  TickFrequency="1" IsSnapToTickEnabled="True"
                  Margin="18,2,18,10"
                  ValueChanged="ThreadsSlider_ValueChanged"/>

          <!-- Разделитель -->
          <Border Height="1" Background="{StaticResource BrushBorder}" Margin="18,6"/>

          <!-- ОПЦИИ -->
          <TextBlock Text="{x:Static res:Strings.SectionOptions}" FontSize="10"
                     Foreground="{StaticResource BrushDim}"
                     Margin="18,8,18,2"/>

          <CheckBox x:Name="SkipExistingCheck"
                    Content="{x:Static res:Strings.CheckSkipExisting}"
                    IsChecked="True"
                    Style="{StaticResource DarkCheckBox}"
                    Margin="18,4,18,4"/>

          <CheckBox x:Name="DryRunCheck"
                    Content="{x:Static res:Strings.CheckDryRun}"
                    IsChecked="False"
                    Style="{StaticResource DarkCheckBox}"
                    Margin="18,0,18,14"/>

        </StackPanel>
      </ScrollViewer>

      <!-- Разделитель между панелями -->
      <Border Grid.Column="1" Background="{StaticResource BrushBorder}"/>

      <!-- ── Правая панель: лог + прогресс ──────────────────────────────── -->
      <Grid Grid.Column="2" Background="{StaticResource BrushBg}">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>  <!-- Заголовок лога -->
          <RowDefinition Height="*"/>     <!-- Текст лога     -->
          <RowDefinition Height="Auto"/>  <!-- Прогресс       -->
        </Grid.RowDefinitions>

        <!-- Заголовок лога -->
        <Grid Grid.Row="0" Margin="16,12,16,4">
          <TextBlock Text="{x:Static res:Strings.SectionLog}" FontSize="10"
                     Foreground="{StaticResource BrushDim}"
                     VerticalAlignment="Center"/>
          <Button Content="{x:Static res:Strings.BtnClearLog}"
                  HorizontalAlignment="Right"
                  Style="{StaticResource GhostButton}"
                  Click="ClearLog_Click"/>
        </Grid>

        <!-- Текстовое поле лога -->
        <TextBox x:Name="LogBox"
                 Grid.Row="1"
                 Background="#0A0A0A"
                 Foreground="{StaticResource BrushText}"
                 FontFamily="Consolas" FontSize="10"
                 BorderBrush="{StaticResource BrushBorder}"
                 BorderThickness="1"
                 Margin="16,0,16,8"
                 Padding="8"
                 IsReadOnly="True"
                 IsReadOnlyCaretVisible="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 AcceptsReturn="True"
                 VerticalContentAlignment="Top"/>

        <!-- Прогресс -->
        <StackPanel Grid.Row="2" Margin="16,0,16,10">
          <ProgressBar x:Name="ProgressBar"
                       Height="5" Minimum="0" Maximum="1" Value="0"
                       Background="{StaticResource BrushBorder}"
                       Foreground="{StaticResource BrushAccent}"
                       BorderThickness="0"/>
          <TextBlock x:Name="ProgressLabel"
                     Text="" FontSize="10"
                     Foreground="{StaticResource BrushDim}"
                     HorizontalAlignment="Right"
                     Margin="0,2,0,0"/>
        </StackPanel>
      </Grid>
    </Grid>

    <!-- Разделитель над нижней панелью -->
    <Border Grid.Row="3" Background="{StaticResource BrushBorder}"/>

    <!-- ── Нижняя панель с кнопками ───────────────────────────────────── -->
    <Border Grid.Row="4" Background="{StaticResource BrushPanel}" Height="52">
      <Grid Margin="16,0">
        <!-- Левые кнопки -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Button x:Name="BtnCheckAccess"
                  Content="{x:Static res:Strings.BtnCheckAccess}"
                  Style="{StaticResource OutlineButton}"
                  Margin="0,0,8,0"
                  Click="BtnCheckAccess_Click"/>
          <Button x:Name="BtnRebuildIndex"
                  Content="{x:Static res:Strings.BtnRebuildIndex}"
                  Style="{StaticResource OutlineButton}"
                  Click="BtnRebuildIndex_Click"/>
        </StackPanel>

        <!-- Таймер по центру -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{StaticResource BrushInput}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1" CornerRadius="3"
                Padding="12,4">
          <TextBlock x:Name="TimerLabel" Text="00:00:00"
                     FontSize="18" FontWeight="Bold" FontFamily="Consolas"
                     Foreground="{StaticResource BrushAccent}"/>
        </Border>

        <!-- Правые кнопки -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                    VerticalAlignment="Center">
          <Button x:Name="BtnStop"
                  Content="{x:Static res:Strings.BtnStop}"
                  Style="{StaticResource StopButton}"
                  IsEnabled="False"
                  Margin="0,0,8,0"
                  Click="BtnStop_Click"/>
          <Button x:Name="BtnStart"
                  Content="{x:Static res:Strings.BtnStart}"
                  Style="{StaticResource AccentButton}"
                  Click="BtnStart_Click"/>
        </StackPanel>
      </Grid>
    </Border>

  </Grid>
</Window>
